<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="?attr/selectableItemBackground"
    android:clickable="true"
    android:focusable="true"
    android:gravity="center_vertical"
    android:minHeight="64dp"
    android:orientation="horizontal"
    android:paddingHorizontal="18dp"
    android:paddingVertical="11dp">

    <!-- Icon badge: 44dp circle (adapter sets oval bg color + emoji) -->
    <FrameLayout
        android:layout_width="44dp"
        android:layout_height="44dp">

        <View
            android:id="@+id/viewIconBg"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_circle_primary" />

        <TextView
            android:id="@+id/textCategoryIcon"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:gravity="center"
            android:text="?"
            android:textSize="19sp" />

        <ImageView
            android:id="@+id/imageCategoryIcon"
            android:layout_width="21dp"
            android:layout_height="21dp"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <!-- Center column: name + subtitle -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="13dp"
        android:layout_weight="1"
        android:orientation="vertical">

        <!-- Name / category (title) -->
        <TextView
            android:id="@+id/textCategory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:ellipsize="end"
            android:fontFamily="sans-serif-medium"
            android:maxLines="1"
            android:textColor="@color/text_primary"
            android:textSize="14.5sp" />

        <!-- Subtitle: wallet -->
        <TextView
            android:id="@+id/textWallet"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/text_secondary"
            android:textSize="12sp" />

        <!-- Note (hidden when empty) -->
        <TextView
            android:id="@+id/textNote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:textColor="@color/text_secondary"
            android:textSize="11.5sp"
            android:visibility="gone" />
    </LinearLayout>

    <!-- Right column: amount + date/time -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="10dp"
        android:gravity="end"
        android:orientation="vertical">

        <TextView
            android:id="@+id/textAmount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/text_primary"
            android:textSize="14.5sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textDateTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="3dp"
            android:textColor="@color/brand_faint"
            android:textSize="11sp" />
    </LinearLayout>
</LinearLayout>
