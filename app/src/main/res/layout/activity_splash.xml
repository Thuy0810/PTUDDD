<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_hero_gradient">

    <!-- vong trang trang tri (goc tren phai) -->
    <View
        android:layout_width="220dp"
        android:layout_height="220dp"
        android:layout_gravity="top|end"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-50dp"
        android:alpha="0.10"
        android:background="@drawable/bg_circle_white" />

    <!-- vong cam trang tri (goc duoi trai) -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:layout_gravity="bottom|start"
        android:layout_marginStart="-50dp"
        android:layout_marginBottom="80dp"
        android:alpha="0.28"
        android:background="@drawable/bg_circle_orange" />

    <!-- noi dung trung tam: logo + ten -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <FrameLayout
            android:layout_width="92dp"
            android:layout_height="92dp"
            android:background="@drawable/bg_splash_logo">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="X"
                android:textColor="@color/white"
                android:textSize="50sp"
                android:textStyle="bold" />
        </FrameLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/brand_short"
            android:textColor="@color/white"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="@string/s3_app_tagline"
            android:textColor="#D9FFFFFF"
            android:textSize="14sp" />
    </LinearLayout>

    <!-- spinner + phien ban (duoi man) -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="38dp"
        android:gravity="center_horizontal"
        android:orientation="vertical">

        <ProgressBar
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:indeterminate="true"
            android:indeterminateTint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:text="@string/app_version"
            android:textColor="#B3FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>
</FrameLayout>
