rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId} {
      allow create, read, update, delete:
        if request.auth != null
        && request.auth.uid == userId;
    }

    match /users/{userId}/transactions/{transactionId} {
      allow create, read, update, delete:
        if request.auth != null
        && request.auth.uid == userId;
    }

    match /users/{userId}/categories/{categoryId} {
      allow create, read, update, delete:
        if request.auth != null
        && request.auth.uid == userId;
    }

    match /users/{userId}/wallets/{walletId} {
      allow create, read, update, delete:
        if request.auth != null
        && request.auth.uid == userId;
    }

    match /users/{userId}/budgets/{document=**} {
      allow read, write:
        if request.auth != null
        && request.auth.uid == userId;
    }

    match /users/{userId}/recurring/{document=**} {
      allow read, write:
        if request.auth != null
        && request.auth.uid == userId;
    }

    match /users/{userId}/savings_goals/{document=**} {
      allow read, write:
        if request.auth != null
        && request.auth.uid == userId;
    }

    match /users/{userId}/savings_challenges/{document=**} {
      allow read, write:
        if request.auth != null
        && request.auth.uid == userId;
    }
  }
}