<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Theme chinh - giao dien sang, mau kem, phong cach Eggu -->
    <style name="Theme.ExpenseManager" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>

        <!-- Card style -->
        <item name="materialCardViewStyle">@style/Widget.ExpenseManager.CardView</item>

        <!-- Button style -->
        <item name="materialButtonStyle">@style/Widget.ExpenseManager.Button</item>

        <!-- TextInputLayout style -->
        <item name="textInputStyle">@style/Widget.ExpenseManager.TextInputLayout</item>
    </style>

    <!-- Theme co ActionBar -->
    <style name="Theme.ExpenseManager.WithActionBar" parent="Theme.Material3.Light">
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryDark">@color/primary_dark</item>
        <item name="colorAccent">@color/accent</item>
        <item name="colorOnPrimary">@color/text_on_primary</item>
        <item name="android:statusBarColor">@color/primary_dark</item>
        <item name="android:windowBackground">@color/background</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Theme Splash -->
    <style name="Theme.ExpenseManager.Splash" parent="Theme.ExpenseManager">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@drawable/bg_hero_gradient</item>
        <item name="android:statusBarColor">@color/brand_blue_dark</item>
        <item name="android:navigationBarColor">@color/brand_blue_deep</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Theme Auth (Onboarding/Login) - khong action bar, header gradient xanh -->
    <style name="Theme.ExpenseManager.Auth" parent="Theme.ExpenseManager">
        <item name="colorPrimary">@color/brand_blue</item>
        <item name="colorPrimaryDark">@color/brand_blue_dark</item>
        <item name="android:statusBarColor">@color/brand_blue_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
        <item name="android:windowBackground">@color/brand_bg</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- === CUSTOM WIDGET STYLES === -->

    <!-- Card view - bo goc lon, shadow nhe -->
    <style name="Widget.ExpenseManager.CardView" parent="Widget.Material3.CardView.Elevated">
        <item name="cardCornerRadius">20dp</item>
        <item name="cardElevation">2dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
        <item name="contentPadding">16dp</item>
    </style>

    <!-- Primary button - mau cam -->
    <style name="Widget.ExpenseManager.Button" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/primary</item>
        <item name="android:textColor">@color/white</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
        <item name="android:textSize">15sp</item>
        <item name="android:fontFamily">sans-serif-medium</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
    </style>

    <!-- Outlined button -->
    <style name="Widget.ExpenseManager.Button.Outlined" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/primary</item>
        <item name="android:textColor">@color/primary</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- Text button -->
    <style name="Widget.ExpenseManager.Button.Text" parent="Widget.Material3.Button.TextButton">
        <item name="android:textColor">@color/primary</item>
        <item name="android:textAllCaps">false</item>
    </style>

    <!-- TextInputLayout -->
    <style name="Widget.ExpenseManager.TextInputLayout" parent="Widget.Material3.TextInputLayout.OutlinedBox">
        <item name="boxCornerRadiusTopStart">12dp</item>
        <item name="boxCornerRadiusTopEnd">12dp</item>
        <item name="boxCornerRadiusBottomStart">12dp</item>
        <item name="boxCornerRadiusBottomEnd">12dp</item>
        <item name="boxStrokeColor">@color/primary</item>
        <item name="hintTextColor">@color/primary</item>
    </style>

    <!-- Bottom Navigation -->
    <style name="Widget.ExpenseManager.BottomNavigation" parent="Widget.Material3.BottomNavigationView">
        <item name="backgroundTint">@color/white</item>
        <item name="itemActiveIndicatorStyle">@style/Widget.ExpenseManager.BottomNavigation.ActiveIndicator</item>
        <item name="itemIconTint">@color/bottom_nav_color</item>
        <item name="itemTextColor">@color/bottom_nav_color</item>
        <item name="labelVisibilityMode">labeled</item>
    </style>

    <style name="Widget.ExpenseManager.BottomNavigation.ActiveIndicator" parent="Widget.Material3.BottomNavigationView.ActiveIndicator">
        <item name="android:color">@color/primary_light</item>
    </style>

    <!-- FAB style -->
    <style name="Widget.ExpenseManager.FAB" parent="Widget.Material3.FloatingActionButton.Primary">
        <item name="backgroundTint">@color/primary</item>
        <item name="tint">@color/white</item>
        <item name="shapeAppearance">@style/ShapeAppearance.ExpenseManager.FAB</item>
    </style>

    <style name="ShapeAppearance.ExpenseManager.FAB" parent="ShapeAppearance.Material3.Corner.Full">
        <item name="cornerSize">50%</item>
    </style>

    <!-- Text styles -->
    <style name="TextAppearance.ExpenseManager.Headline" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.ExpenseManager.Title" parent="TextAppearance.Material3.TitleMedium">
        <item name="android:textColor">@color/text_primary</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.ExpenseManager.Body" parent="TextAppearance.Material3.BodyMedium">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="TextAppearance.ExpenseManager.Caption" parent="TextAppearance.Material3.BodySmall">
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <!-- Amount text -->
    <style name="TextAppearance.ExpenseManager.Amount" parent="TextAppearance.Material3.HeadlineLarge">
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>

    <style name="TextAppearance.ExpenseManager.Amount.Income">
        <item name="android:textColor">@color/income_green</item>
    </style>

    <style name="TextAppearance.ExpenseManager.Amount.Expense">
        <item name="android:textColor">@color/expense_red</item>
    </style>
</resources>
